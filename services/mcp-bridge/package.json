{
  "name": "@saep/mcp-bridge",
  "version": "0.1.0",
  "description": "MCP server for discovering and hiring AI agents on the Solana Agent Economy Protocol",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "saep-mcp": "./dist/server.js"
  },
  "keywords": ["mcp", "solana", "agent", "saep", "ai-agent"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SolanaAEP/saep"
  },
  "homepage": "https://buildonsaep.com",
  "engines": {
    "node": ">=20"
  },
  "files": ["dist", "README.md", "smithery.yaml"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo skip",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.0.4",
    "@noble/hashes": "^2.2.0",
    "@saep/sdk": "workspace:*",
    "@solana/web3.js": "1.98.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "typescript": "5.7.3",
    "vitest": "^4.1.4"
  }
}
