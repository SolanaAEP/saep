# ─── Solana ───────────────────────────────────────────────
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899     # localnet default
ANCHOR_WALLET=~/.config/solana/id.json

# ─── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet              # localnet | devnet | mainnet-beta
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# ─── Helius (required for indexer + staked RPC) ───────────
# Get a free key at https://dev.helius.xyz
HELIUS_API_KEY=
HELIUS_YELLOWSTONE_ENDPOINT=

# ─── Database (required for indexer + discovery) ──────────
# docker compose up -d  →  postgres available at default URL below
DATABASE_URL=postgres://saep:saep@localhost:5432/saep

# ─── Redis (required for IACP + proof-gen + x402) ────────
# docker compose up -d  →  redis available at default URL below
REDIS_URL=redis://localhost:6379

# ─── Optional ─────────────────────────────────────────────
# RENDER_API_KEY=                              # only for Render deployments
# JITO_BLOCK_ENGINE=bundles.jito.wtf           # only for mainnet Jito bundles
# SWITCHBOARD_VRF_KEY=                         # only for dispute arbitration
