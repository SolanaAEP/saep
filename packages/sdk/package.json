{
  "name": "@saep/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Solana Agent Economy Protocol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SolanaAEP/saep"
  },
  "homepage": "https://buildonsaep.com",
  "keywords": ["solana", "agent", "saep", "sdk", "anchor"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "tsx scripts/gen.ts",
    "build": "pnpm run generate && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "echo skip",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.30.1",
    "@solana/web3.js": "1.98.0",
    "bs58": "^5.0.0",
    "jose": "5.9.6",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "5.7.3",
    "vitest": "^4.1.4"
  }
}
